# ====================================================
# PROJECT MASS — Configuration Google Sheets
# ====================================================
# Copie ce fichier en .env.local et remplis les valeurs
# Voir SETUP.md pour les instructions complètes

# ID du Google Sheet (dans l'URL : spreadsheets/d/XXXX/edit)
GOOGLE_SPREADSHEET_ID=

# Credentials Service Account (JSON sur une seule ligne)
# Format: {"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optionnel : mot de passe pour protéger l'app
# APP_PASSWORD=monmotdepasse

# Optionnel : Coach IA
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
